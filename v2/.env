# Root environment settings for this workspace
# Keep real secrets only in this file (do not commit)

ENVIRONMENT=development
PROJECT_NAME=NodeTest

# Agent bootstrap behavior
SESSION_MODE=clean
FULL_SESSION_TRIGGERS=Привет,Hi

# Add your private keys below (example format)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ─── Docker / инфраструктура ──────────────────────────────────────────────
# Путь к vault на хост-машине (используется в docker-compose.yml)
VAULT_PATH=/path/to/your/vault

# Модель эмбеддингов Ollama
EMBED_MODEL=nomic-embed-text

# Часовой пояс
TZ=Europe/Moscow

# n8n — логин для UI (http://localhost:5678)
N8N_USER=admin
N8N_PASSWORD=changeme
