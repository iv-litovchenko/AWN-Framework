views:
  - type: table
    name: Таблица
    filters:
      and:
        - note["AWN-ROLE"].containsAny("COMPONENT", "MEMORY")
    order:
      - file.name
      - file.basename
      - file.fullname
      - file.tags
      - AWN-ID
      - AWN-ROLE
      - AWN-TYPE
    sort:
      - property: AWN-ROLE
        direction: ASC
      - property: file.name
        direction: ASC
