views:
  - type: table
    name: Таблица
    filters:
      and:
        - note["AWN-ROLE"].containsAny("COMPONENT", "MEMORY")
    order:
      - file.folder
      - file.name
      - AWN-ID
      - AWN-ROLE
      - AWN-TYPE
      - file.tags
    sort:
      - property: file.folder
        direction: ASC
      - property: AWN-ROLE
        direction: ASC
      - property: file.name
        direction: ASC
