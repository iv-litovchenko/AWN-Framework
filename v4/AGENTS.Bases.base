views:
  - type: table
    name: Core repository
    filters:
      and:
        - file.path.contains(".base")
    order:
      - file.name
      - file.backlinks
      - file.ctime
      - file.embeds
      - file.ext
      - file.folder
      - file.fullname
      - file.links
      - file.mtime
      - file.basename
      - file.path
      - file.size
      - file.tags
  - type: table
    name: Media repository
    imageAspectRatio: 1.05
  - type: table
    name: Content repository
  - type: table
    name: Flow repository
  - type: table
    name: Nodes repository
  - type: table
    name: Bases repository
