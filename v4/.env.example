# Скопируйте в `.env` и подставьте свои значения.
# Файл `.env` не коммитить (секреты и локальные пути).

ENVIRONMENT=development
PROJECT_NAME=AWN-Framework

# Режим первого сообщения агента: clean | full (если используете в оболочке)
SESSION_MODE=clean
FULL_SESSION_TRIGGERS=Привет,Hi

# Пример API-ключей (раскомментируйте при необходимости)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ─── Docker Compose (docker-compose.yml) ─────────────────────────────────
# Абсолютный путь к vault на хосте (для тома :ro в контейнерах)
VAULT_PATH=/absolute/path/to/your/vault

EMBED_MODEL=nomic-embed-text
TZ=Europe/Moscow

N8N_USER=admin
N8N_PASSWORD=change-me

# ─── WireGuard (wg-easy) ───────────────────────────────────────────────────
# Публичный IP или домен вашего сервера (куда подключаются клиенты)
WG_HOST=your.server.ip.or.domain
# Пароль для web UI wg-easy (http://localhost:51821)
WG_PASSWORD=change-me-strong
