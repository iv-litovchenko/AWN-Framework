filters:
  and:
    - file.ext == "md"
    - file.inFolder("v3/awn-tests/mdbase-demo/people")
properties:
  full_name:
    displayName: Full Name
  team:
    displayName: Team
  role:
    displayName: Role
  email:
    displayName: Email
  file.path:
    displayName: Path
views:
  - type: table
    name: People
    order:
      - full_name
      - team
      - role
      - email
      - file.path
    sort:
      - property: full_name
        direction: ASC
  - type: table
    name: People by team
    groupBy:
      property: team
      direction: ASC
    order:
      - team
      - full_name
      - role
      - email
