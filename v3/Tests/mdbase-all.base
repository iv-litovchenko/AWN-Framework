filters:
  and:
    - file.ext == "md"
    - file.inFolder("v3/Tests")
properties:
  type:
    displayName: Type
  title:
    displayName: Title
  assignee:
    displayName: Assignee
  due_date:
    displayName: Due
  status:
    displayName: Status
  priority:
    displayName: Priority
  full_name:
    displayName: Full Name
  team:
    displayName: Team
  role:
    displayName: Role
  email:
    displayName: Email
  frequency:
    displayName: Frequency
  streak_days:
    displayName: Streak
  active:
    displayName: Active
  file.path:
    displayName: Path
views:
  - type: table
    name: All demo notes
    filters:
      or:
        - file.inFolder("v3/Tests/mdbase-demo/tasks")
        - file.inFolder("v3/Tests/mdbase-demo/people")
        - file.inFolder("v3/Tests/mdbase-habits-demo/habits")
    order:
      - type
      - title
      - full_name
      - status
      - priority
      - team
      - frequency
      - streak_days
      - active
      - file.path
  - type: table
    name: Only tasks
    filters:
      and:
        - file.inFolder("v3/Tests/mdbase-demo/tasks")
    order:
      - title
      - status
      - priority
      - assignee
      - due_date
      - file.path
  - type: table
    name: Only people
    filters:
      and:
        - file.inFolder("v3/Tests/mdbase-demo/people")
    order:
      - full_name
      - team
      - role
      - email
      - file.path
  - type: table
    name: Only habits
    filters:
      and:
        - file.inFolder("v3/Tests/mdbase-habits-demo/habits")
    order:
      - title
      - frequency
      - streak_days
      - active
      - file.path
